{
  "name": "avanca-hospital-caninde-db",
  "version": "0.0.0",
  "private": true,
  "description": "Camada de banco e frontend est횄징tico do GSI ONE / Avan횄짠a Hospital Canind횄짤, com funda횄짠횄짙o m횄짯nima de QA.",
  "scripts": {
